{
  "debug.javascript.terminalOptions": {
    "resolveSourceMapLocations": [
      "${workspaceFolder}/**",
      "!**/node_modules/**",
      "**/node_modules/.vite-temp/**"
    ]
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "css.customData": [
    "./.vscode/custom-elements-manifest/vscode.css-custom-data.json"
  ],
  "html.customData": [
    "./.vscode/custom-elements-manifest/vscode.html-custom-data.json"
  ],
  "postcssense.cssPath": "./src/index.css",
  "lit-plugin.logging": "verbose",
  "lit-plugin.rules.no-expressionless-property-binding": "error",
  "lit-plugin.rules.no-missing-element-type-definition": "error",
  "lit-plugin.rules.no-unknown-slot": "error",
  "stylelint.configFile": "./stylelint.config.ts",
  "stylelint.packageManager": "pnpm",
  "stylelint.run": "onSave",
  "stylelint.snippet": [
    "css",
    "postcss",
  ],
  "stylelint.validate": [
    "css",
    "javascript",
    "postcss",
    "typescript",
  ],
  "tailwindCSS.experimental.configFile": "./.config/tailwind/tailwind.config.ts"
}