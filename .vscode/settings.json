{
  "debug.javascript.terminalOptions": {
    "resolveSourceMapLocations": [
      "${workspaceFolder}/**",
      "!**/node_modules/**",
      "**/node_modules/.vite-temp/**"
    ]
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "css.customData": [
    "./dist/vscode.css-custom-data.json"
  ],
  "html.customData": [
    "./dist/vscode.html-custom-data.json"
  ],
  "postcssense.cssPath": "./src/index.css",
  "stylelint.configFile": "./stylelint.config.ts",
  "stylelint.packageManager": "npm",
  "stylelint.run": "onSave",
  "stylelint.snippet": [
    "css",
    "postcss",
  ],
  "stylelint.validate": [
    "css",
    "javascript",
    "postcss",
    "typescript",
  ],
  "tailwindCSS.experimental.configFile": "./.config/tailwind.config.ts"
}