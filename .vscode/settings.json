{
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "cem.additionalPackages": [
    "npm:@material/web"
  ],
  "cem.lsp.debugLogging": true,
  "cem.lsp.executable": "",
  "cem.lsp.trace.server": "verbose",
  "css.customData": [
    "./.vscode/custom-elements-manifest/vscode.css-custom-data.json"
  ],
  "css.lint.importStatement": "ignore",
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "~/.local/share/mise/shims/node"
  },
  "debug.javascript.terminalOptions": {
    "resolveSourceMapLocations": [
      "./**",
      "!**/node_modules/**",
      "**/node_modules/.vite-temp/**"
    ]
  },
  "docthis.returnsTag": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": false,
  "editor.formatOnSaveMode": "file",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": false,
    "**/.hg": true,
    "**/.plugin_symlinks": true,
    "**/.ruby-lsp": true,
    "**/.svn": true,
    "**/.symlinks": true,
    "**/CVS": true,
    "**/flutter/ephemeral": true,
    "**/Flutter/ephemeral": true,
    "**/Thumbs.db": true
  },
  "html.customData": [
    "./.vscode/custom-elements-manifest/vscode.html-custom-data.json",
    "./.vscode/wca/*.json"
  ],
  "html.suggest.html5": true,
  "java.import.gradle.java.home": "~/.local/share/mise/installs/java/temurin-26.0.1+8",
  "java.jdt.ls.java.home": "~/.local/share/mise/installs/java/temurin-26.0.1+8",
  "jdk.jdkhome": "~/.local/share/mise/installs/java/temurin-26.0.1+8",
  "js/ts.tsdk.path": "./node_modules/typescript/lib",
  "lit-html.format.enabled": true,
  "lit-plugin.logging": "verbose",
  "lit-plugin.rules.no-expressionless-property-binding": "error",
  "lit-plugin.rules.no-missing-element-type-definition": "error",
  "lit-plugin.rules.no-unknown-slot": "error",
  "npm.packageManager": "pnpm",
  "npm.scriptRunner": "pnpm",
  "outline.collapseItems": "alwaysCollapse",
  "oxc.fmt.configPath": "./vite.config.ts",
  "pnpm-vscode-helper.enableCodelen": true,
  "pnpm.packageJson": "./package.json",
  "postcssense.cssPath": "./src/index.css",
  "stylelint.configFile": "./stylelint.config.ts",
  "stylelint.packageManager": "pnpm",
  "stylelint.run": "onSave",
  "stylelint.snippet": [
    "css",
    "postcss"
  ],
  "stylelint.validate": [
    "css",
    "javascript",
    "postcss",
    "typescript"
  ],
  "tailwindCSS.experimental.configFile": "./.config/tailwind/tailwind.config.ts",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.tree.indent": 4
}