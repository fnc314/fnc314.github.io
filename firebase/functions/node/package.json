    "@typescript-eslint/parser": "catalog:devDependencies",
    "eslint": "catalog:devDependencies",
    "eslint-config-google": "catalog:devDependencies",
    "eslint-plugin-import": "catalog:devDependencies",
    "firebase-functions-test": "catalog:functionsDevDependencies",
    "typescript": "catalog:devDependencies"
  },
  "overrides": {
    "uuid": "catalog:overrides"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "engines": {
    "node": "26.5.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
