    "@typescript-eslint/parser": "catalog:devDependencies",
    "eslint": "catalog:devDependencies",
    "eslint-config-google": "catalog:devDependencies",
    "eslint-plugin-import": "catalog:devDependencies",
    "firebase-functions-test": "catalog:functionsDevDependencies",
    "typescript": "catalog:devDependencies"
  },
  "overrides": {
    "uuid": "catalog:overrides"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": "26.5.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
