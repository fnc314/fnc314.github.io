{
  "name": "@fnc314/functions.node",
  "version": "2.0.6",
  "private": true,
  "description": "Firebase Cloud Functions for www.fnc314.com",
  "author": "Franco N. Colaizzi",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
