{
  "name": "@fnc314/design-tokens",
  "version": "0.1.0",
  "description": "Design tokens for fnc314.github.io, managed by Style Dictionary.",
  "author": "Franco N. Colaizzi",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "style": "./dist/css/_variables.css"
    },
    "./dist/*": "./dist/*",
    "./themes/*": "./dist/themes/*.json",
    "./src/*": "./src/*.json",
    "./styles/*": "./dist/css/_variables.css"
  },
  "dependencies": {},
  "devDependencies": {
    "fs-extra": "catalog:devDependencies",
    "style-dictionary": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "vite": "catalog:devDependencies"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary"
  ],
  "engines": {
    "node": "26.3.0"
  }
}