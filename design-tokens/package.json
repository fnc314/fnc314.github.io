{
  "name": "@fnc314/design-tokens",
  "version": "0.1.0",
  "description": "Design tokens for fnc314.github.io, managed by Style Dictionary.",
  "author": "Franco N. Colaizzi",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "style": "./dist/css/_variables.css",
      "import": "./dist/jsno/tokens.json",
      "default": "./dist/json/tokens.json"
    },
    "./themes/*": "./dist/themes/*",
    "./css/*": "./dist/css/*",
    "./json/*": "./dist/json/*"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/fs-extra": "catalog:devDependencies",
    "fs-extra": "catalog:devDependencies",
    "style-dictionary": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "vite": "catalog:devDependencies"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary"
  ],
  "engines": {
    "node": "26.3.0"
  }
}