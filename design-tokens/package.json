{
  "name": "@fnc314/design-tokens",
  "version": "2.0.0",
  "description": "Design tokens for fnc314.github.io, managed by Style Dictionary.",
  "author": "Franco N. Colaizzi",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "style": "./dist/@fnc314.design-tokens.css",
      "import": "./dist/@fnc314.design-tokens.js",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/@fnc314.design-tokens.js"
    },
    "./styles.css": {
      "style": "./dist/@fnc314.design-tokens.css",
      "default": "./dist/@fnc314.design-tokens.css"
    },
    "./css/*": {
      "style": "./dist/css/*",
      "default": "./dist/@fnc314.design-tokens.css"
    },
    "./icons/*": "./dist/icons/*",
    "./json/*": "./dist/json/*",
    "./themes/*": "./dist/themes/*",
    "./types/*": "./dist/types/*",
    "./dist/*": "./dist/*"
  },
  "files": [
    "./dist/@fnc314.design-tokens.css",
    "./dist/@fnc314.design-tokens.js",
    "./dist/icons/**/*",
    "./dist/types/**/*.d.ts",
    "./dist/themes/**/*.{jpg,json}",
    "./dist/css/*.css",
    "./dist/json/*.json"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/@fnc314.design-tokens.js",
  "module": "./dist/@fnc314.design-tokens.js",
  "dependencies": {
    "@material/web": "catalog:dependencies",
    "material-symbols": "catalog:dependencies"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:devDependencies",
    "fs-extra": "catalog:devDependencies",
    "style-dictionary": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unplugin-dts": "catalog:devDependencies",
    "vite": "catalog:devDependencies"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary"
  ],
  "engines": {
    "node": "26.3.1"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
