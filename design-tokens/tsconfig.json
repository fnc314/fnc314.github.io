{
  "extends": [
    "./../tsconfig.json",
  ],
  "compilerOptions": {
    "types": [
      "@types/fs-extra"
    ],
    "outDir": "dist/js",
    "emitDeclarationOnly": false,
    "noEmit": false,
    "allowJs": true,
    "emitDecoratorMetadata": false,
    "alwaysStrict": true,
    "checkJs": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "Decorators",
      "DOM",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ES2025",
      "ESNext"
    ],
    "rootDir": ".",
    "paths": {
      "@/*": ["./scripts/*"]
    },
    "preserveConstEnums": true,
    "pretty": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "rewriteRelativeImportExtensions": true,
    "target": "esnext",
    "tsBuildInfoFile": "./../stats/design-tokens.tsbuildinfo",
  }
}