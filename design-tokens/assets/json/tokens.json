  "md": {
    "filled": {
      "button": {
        "container": {
          "shape": "var(--md-sys-shape-corner-small)"
        }
      }
    },
    "outlined": {
      "button": {
        "container": {
          "shape": "var(--md-sys-shape-corner-small)"
        }
      }
    },
    "elevated": {
      "card": {
        "container": {
          "shadow": {
            "color": "oklch(from var(--md-sys-color-scrim) 30% c h)"
          }
        }
      }
    },
    "icon": {
      "size": "1.5rem",
      "font": "\"Material Symbols Outlined\"",
      "fontSharp": "\"Material Symbols Sharp\""
    },
    "sys": {
      "shape": {
        "corner": {
          "extra-large": "2rem",
          "extra-small": "0.25rem",
          "full": "100%",
          "large": "1.5rem",
          "medium": "1rem",
          "none": "0",
          "small": "0.5rem"
        }
      },
      "typescale": {
        "body": {
          "large": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1.5rem",
            "size": "1rem",
            "weight": "400"
          },
          "medium": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1.25rem",
            "size": "0.875rem",
            "weight": "400"
          },
          "small": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1rem",
            "size": "0.75rem",
            "weight": "400"
          }
        },
        "display": {
          "large": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "4rem",
            "size": "3.5625rem",
            "weight": "400"
          },
          "medium": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "3.25rem",
            "size": "2.8125rem",
            "weight": "400"
          },
          "small": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "2.75rem",
            "size": "2.25rem",
            "weight": "400"
          }
        },
        "headline": {
          "large": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "2.5rem",
            "size": "2rem",
            "weight": "400"
          },
          "medium": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "2.25rem",
            "size": "1.75rem",
            "weight": "400"
          },
          "small": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "2rem",
            "size": "1.5rem",
            "weight": "400"
          }
        },
        "label": {
          "large": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1.25rem",
            "size": "0.875rem",
            "weight": "500",
            "weightProminent": "700"
          },
          "medium": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1rem",
            "size": "0.75rem",
            "weight": "500",
            "weightProminent": "700"
          },
          "small": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1rem",
            "size": "0.6875rem",
            "weight": "500"
          }
        },
        "title": {
          "large": {
            "font": "var(--md-ref-typeface-brand)",
            "lineHeight": "1.75rem",
            "size": "1.375rem",
            "weight": "400"
          },
          "medium": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1.5rem",
            "size": "1rem",
            "weight": "500"
          },
          "small": {
            "font": "var(--md-ref-typeface-plain)",
            "lineHeight": "1.25rem",
            "size": "0.875rem",
            "weight": "500"
          }
        }
      }
    },
    "fonts": {
      "material": {
        "symbols": {
          "sharp": {
            "family": "\"Material Symbols Sharp\"",
            "face": {
              "weight": {
                "min": 100,
                "max": 700
              }
            },
            "weight": "normal",
            "size": "24px",
            "line-height": "1"
          },
          "outlined": {
            "family": "\"Material Symbols Outlined\"",
            "face": {
              "weight": {
                "min": 100,
                "max": 700
              }
            },
            "weight": "normal",
            "size": "24px",
            "line-height": "1"
          }
        }
      }
    },
    "ref": {
      "typeface": {
        "brand": "monospace",
        "plain": "inter, sans-serif",
        "weight": {
          "regular": "400",
          "medium": "500",
          "bold": "700"
        }
      }
    }
  },
  "motions": {
    "duration": {
      "none": "0ms",
      "short": "250ms",
      "medium": "300ms"
    },
    "easing": {
      "emphasized": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "base": "ease-in-out"
    },
    "elevation": {
      "level-0": "0",
      "level-1": "1",
      "level-2": "2",
      "level-3": "3",
      "level-4": "4",
      "level-5": "5"
    },
    "transform": {
      "hover-lift": "-4px"
    },
    "rotation": {
      "90": "90deg",
      "180": "180deg",
      "270": "270deg",
      "none": "0deg"
    }
  },
  "sizes": {
    "height": {
      "l": "1.5rem",
      "m": "1rem",
      "s": "0.75rem",
      "xl": "2rem",
      "xs": "0.5rem",
      "xxl": "3rem",
      "xxxl": "4rem",
      "xxs": "0.25rem",
      "xxxs": "0.125rem"
    },
    "none": "0",
    "ratio": {
      "square": "1",
      "tall": "9 / 16",
      "wide": "16 / 9"
    },
    "thickness": {
      "hairline": "1px",
      "l": "7px",
      "m": "6px",
      "s": "5px",
      "xl": "8px",
      "xs": "4px",
      "xxl": "9px",
      "xxs": "3px"
    },
    "width": {
      "l": "1.5rem",
      "m": "1rem",
      "s": "0.75rem",
      "xl": "2rem",
      "xs": "0.5rem",
      "xxl": "3rem",
      "xxxl": "4rem",
      "xxs": "0.25rem",
      "xxxs": "0.125rem"
    }
  },
  "spaces": {
    "none": "0",
    "padding": {
      "xxs": "0.25rem",
      "xs": "0.5rem",
      "s": "1rem",
      "m": "1.5rem",
      "l": "2rem",
      "xl": "2.5rem",
      "xxl": "3rem"
    },
    "margin": {
      "xxs": "0.2rem",
      "xs": "0.4rem",
      "s": "0.8rem",
      "m": "1.2rem",
      "l": "1.6rem",
      "xl": "2.4rem",
      "xxl": "3rem"
    },
    "gap": {
      "xxs": "0.2rem",
      "xs": "0.4rem",
      "s": "0.8rem",
      "m": "1.2rem",
      "l": "1.6rem",
      "xl": "2.4rem",
      "xxl": "3rem"
    }
  }
}
