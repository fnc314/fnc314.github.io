{
  "breakpoint": {
    "mobile": {
      "max": "768px"
    },
    "tablet": {
      "min": "769px",
      "max": "1200px"
    },
    "desktop": {
      "min": "1201px"
    }
  },
  "button": {
    "container": {
      "shape": "var(--md-sys-shape-corner-small)"
    }
