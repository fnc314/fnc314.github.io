{
  "dark-mode-toggle": {
    "dark": {
      "icon": {
        "type": "value",
        "value": "var(--icons-components-ui-mode-toggle-dark-empty-css-url)"
      }
    },
    "light": {
      "icon": {
        "type": "value",
        "value": "var(--icons-components-ui-mode-toggle-light-empty-css-url)"
      }
    },
    "system": {
      "icon": {
        "type": "value",
        "value": "var(--icons-components-ui-mode-toggle-default-empty-css-url)"
      }
    },
    "checkbox": {
      "icon": {
        "type": "value",
        "value": "var(--icons-components-ui-mode-toggle-check-box-light-css-url)"
      }
    },
    "remember": {
      "icon": {
        "checked": {
          "type": "value",
          "value": "var(--icons-components-ui-mode-toggle-remember-checked-light-css-url)"
        },
        "unchecked": {
          "type": "value",
          "value": "var(--icons-components-ui-mode-toggle-remember-unchecked-light-css-url)"
        }
      }
