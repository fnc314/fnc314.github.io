{
  "$schema": "https://raw.githubusercontent.com/firebase/firebase-tools/refs/heads/main/schema/firebase-config.json",
  "firestore": {
    "database": "(default)",
    "location": "us-east1",
    "rules": "./firebase/firestore/firestore.rules",
    "indexes": "./firebase/firestore/firestore-indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
      "predeploy": [
        "pnpm --prefix \"$RESOURCE_DIR\" run lint",
        "pnpm --prefix \"$RESOURCE_DIR\" run build"
      ]
    },
    {
      "source": "functions-python",
      "codebase": "python-api",
      "ignore": [
        "venv",
        ".venv",
        "__pycache__",
        "*.pyc",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "apphosting": {
    "backendId": "com-fnc314-website",
    "rootDir": "src",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "functions"],
    "alwaysDeployFromSource": false,
    "localBuild": true
  }
}