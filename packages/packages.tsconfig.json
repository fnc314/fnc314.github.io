{
  "buildOptions": {
    "incremental": true,
    "traceResolution": true,
    "verbose": true
  },
  "compileOnSave": true,
  "compilerOptions": {
    "allowJs": true,
    "alwaysStrict": true,
    "checkJs": true,
    "composite": true,
    "declaration": true,
    "declarationDir": "./dist",
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "emitDecoratorMetadata": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "inlineSourceMap": false,
    "lib": [
      "Decorators",
      "DOM",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ES2025",
      "ESNext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "./dist",
    "preserveConstEnums": true,
    "pretty": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "${configDir}",
    "sourceMap": false,
    "strictBindCallApply": false,
    "target": "esnext",
    "tsBuildInfoFile": "./../../stats/packages/tsbuildinfo",
    "types": [
      "node",
      "vite/client",
      "material-symbols",
      "@types/fs-extra"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "${configDir}/lib/**/*.ts",
    "${configDir}/index.ts"
  ],
  "ts-node": {
    "compiler": "typescript",
    "logError": true,
    "pretty": true
  },
  "typeAcquisition": {
    "enable": true
  }
}