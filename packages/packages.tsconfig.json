{
  "buildOptions": {
    "incremental": true,
    "traceResolution": true,
    "verbose": true
  },
  "compileOnSave": true,
  "compilerOptions": {
    "allowJs": true,
    "alwaysStrict": true,
    "checkJs": true,
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "inlineSourceMap": false,
    "lib": [
      "Decorators",
      "DOM",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ES2025",
      "ESNext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "${configDir}/dist",
    "preserveConstEnums": true,
    "pretty": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "rewriteRelativeImportExtensions": true,
    "sourceMap": false,
    "strictBindCallApply": false,
    "rootDir": "${configDir}",
    "target": "esnext",
    "useDefineForClassFields": false,
    "types": [
      "node",
      "vite/client",
      "material-symbols",
      "@types/fs-extra",
      "unplugin-info/client"
    ],
    "paths": {
      "@/lib/*": ["${configDir}/lib/*"]
    },
    "declarationDir": "${configDir}/dist/types"
  },
  "exclude": [
    "${configDir}/node_modules",
    "${configDir}/dist",
    ".config",
    "${configDir}/lib/**/*.test.ts"
  ],
  "include": [
    "${configDir}/lib/**/*.ts",
    "${configDir}/lib/env.d.ts"
  ],
  "ts-node": {
    "compiler": "typescript",
    "logError": true,
    "pretty": true
  },
  "typeAcquisition": {
    "enable": true
  }
}