{
  "motion": {
    "duration": {
      "none": {
        "$value": "0ms"
      },
      "short": {
        "$value": "250ms"
      },
      "medium": {
        "$value": "300ms"
      }
    },
    "easing": {
      "emphasized": {
        "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      },
      "standard": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
      },
      "base": {
        "$value": "ease-in-out"
      }
    },
    "elevation": {
      "level-0": "{elevations.beneath}",
      "level-1": "{elevations.lowest}",
      "level-2": "{elevations.low}",
      "level-3": "{elevations.medium}",
      "level-4": "{elevations.high}",
      "level-5": "{elevations.highest}"
    }
  },
  "transform": {
    "hover-lift": {
      "$value": "-4px"
    }
  }
}