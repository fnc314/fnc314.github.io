{
  "name": "@fnc314/packages.design-tokens",
  "version": "2.0.4",
  "description": "Design tokens for fnc314.github.io, managed by Style Dictionary.",
  "author": "Franco N. Colaizzi",
  "license": "ISC",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "style": "./dist/@fnc314.packages.design-tokens.css",
      "import": "./dist/@fnc314.packages.design-tokens.js",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/@fnc314.packages.design-tokens.js"
    },
    "./styles.css": {
      "style": "./dist/@fnc314.packages.design-tokens.css",
      "default": "./dist/@fnc314.packages.design-tokens.css"
    },
    "./css/*": {
      "style": "./dist/css/*",
      "default": "./dist/@fnc314.packages.design-tokens.css"
    },
    "./icons/*": "./dist/icons/*",
    "./json/*": "./dist/json/*",
    "./themes/*": "./dist/themes/*",
    "./types/*": "./dist/types/*",
    "./dist/*": "./dist/*"
  },
  "files": [
    "./dist/@fnc314.packages.design-tokens.css",
    "./dist/@fnc314.packages.design-tokens.js",
    "./dist/icons",
    "./dist/types/**/*.d.ts",
    "./dist/themes/**/*.{jpg,json}",
    "./dist/css/*.css",
    "./dist/json/*.json"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/@fnc314.packages.design-tokens.js",
  "module": "./dist/@fnc314.packages.design-tokens.js",
  "dependencies": {
    "@fnc314/packages.types": "workspace:*",
    "@material/web": "catalog:dependencies",
    "material-symbols": "catalog:dependencies"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:devDependencies",
    "fs-extra": "catalog:devDependencies",
    "style-dictionary": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unplugin-dts": "catalog:devDependencies",
    "vite": "catalog:devDependencies"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary"
  ],
  "engines": {
    "node": "26.4.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
