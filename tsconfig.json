{
  "include": ["./src/*", "src/**/*"],
  "files": ["src/env.d.ts"],
  "exclude": ["node_modules"],
  "typeAcquisition": {
    "enable": true
  },
  "compileOnSave": true,
  "ts-node": {
    "pretty": true,
    "logError": true,
    "compiler": "typescript"
  },
  "buildOptions": {
    "verbose": true,
    "incremental": true,
    "traceResolution": true
  },
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["Decorators", "DOM", "ES2020", "ES2021", "ES2022", "ES2023", "ES2024", "ES2025", "ESNext"],
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": false,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "checkJs": true,
    "declaration": false,
    // "declarationDir": "./website/types",
    "declarationMap": false,
    "emitBOM": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "incremental": true,
    "inlineSources": false,
    "isolatedModules": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./website/types",
    "preserveSymlinks": false,
    "pretty": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "rewriteRelativeImportExtensions": false,
    "rootDir": "./src",
    "sourceMap": false,
    "strict": true,
    "tsBuildInfoFile": "./stats/.tsbuildinfo",
    "useDefineForClassFields": false,
    "verbatimModuleSyntax": false,
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "strict": true
      },
      {
        "name": "@genesiscommunitysuccess/custom-elements-lsp",
        // "srcRouteFromTSServer": "configure this to set the relative path between your project route and your `tsserver.js`",
        // "designSystemPrefix": "configure this to handle a library of components with a prefix",
        "designSystemPrefix": "md-",
        "parser": {
          //   "timeout": 2000,
          "src": "./src",
          "dependencies": [
            "./docs/**/*.json",
            "./.vscode/**/*.json",
            "./node_modules/@material/web"
            //     "configure these globs to find manifest files from your dependencies",
            //     "and use the ! pattern to ignore manifests"
          ]
        }
      }
    ],
    "types": [
      "node",
      "eslint",
      "vite/client",
      "vite-plugin-pwa/client",
      "rollup",
      "postcss"
      // "lit", "prettier", "stylelint", "tailwindcss",
    ],
    "typeRoots": ["./node_modules", "./node_modules/@types", "./node_modules/@web/rollup-plugin-copy/dist"],
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/data/*": ["./src/data/*"],
      "@/services/*": ["./src/services/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/theme/*": ["./src/theme/*"],
      "@/types/*": ["./src/types/*"]
    }
  }
}
