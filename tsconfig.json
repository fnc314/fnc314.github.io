{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "Decorators",
      "DOM",
      "DOM.Iterable",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ESNext",
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": false,
    "emitDecoratorMetadata": true,
    "pretty": true,
    "rootDir": "./src",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "useDefineForClassFields": false,
    "checkJs": true,
    "plugins": [
      {
        "name": "typescript-lit-html-plugin",
      },
      {
        "name": "ts-lit-plugin",
        "strict": true,
        "rules": {
          "no-invalid-css": "off",
        }
      }
    ],
    "types": [
      "node",
      "eslint",
      "rollup",
      "bun-types",
      "lit",
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/components": ["./src/components/*"],
      "@/data": ["./src/data/*"],
      "@/services": ["./src/services/*"],
      "@/styles": ["./src/styles/*"],
      "@/theme": ["./src/theme/*"],
      "@/types": ["./src/types/*"],
    }
  },
  "include": [
    "src/**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "website",
    "old"
  ]
}
