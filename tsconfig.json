{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "buildOptions": {
    "incremental": true,
    "traceResolution": true,
    "verbose": true,
  },
  "compileOnSave": true,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "checkJs": true,
    "declaration": true,
    "declarationDir": "./docs/types",
    "declarationMap": true,
    "emitBOM": true,
    "emitDeclarationOnly": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "incremental": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "isolatedModules": true,
    "lib": [
      "Decorators",
      "DOM",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ES2025",
      "ESNext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist/out",
    "paths": {
      "@/*": ["./*"],
    },
    "plugins": [
      // {
      //   "name": "ts-lit-plugin",
      //   "strict": true
      // },
      {
        // "srcRouteFromTSServer": "configure this to set the relative path between your project route and your `tsserver.js`",
        // "designSystemPrefix": "configure this to handle a library of components with a prefix",
        "designSystemPrefix": "md-",
        "name": "@genesiscommunitysuccess/custom-elements-lsp",
        "parser": {
          "dependencies": [
            "./docs/**/*.json",
            "./.vscode/**/*.json",
            "./node_modules/@material/web",
            //     "configure these globs to find manifest files from your dependencies",
            //     "and use the ! pattern to ignore manifests"
          ],
          //   "timeout": 2000,
        },
      },
    ],
    "preserveConstEnums": true,
    "preserveSymlinks": false,
    "pretty": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictBindCallApply": false,
    "target": "esnext",
    "tsBuildInfoFile": "./stats/.tsbuildinfo",
    "types": [
      "node",
      "eslint",
      "vite/client",
      "vite-plugin-pwa/client",
      "vite-plugin-pwa/pwa-assets",
      "custom-elements-manifest/schema",
      "@web-types/lit",
      "unplugin-info/client",
      "material-symbols",
      "@fnc314/packages.components",
      "@fnc314/packages.data",
      "@fnc314/packages.design-tokens",
      "@fnc314/packages.services",
      "@fnc314/packages.types",
    ],
    "useDefineForClassFields": false,
    "verbatimModuleSyntax": false
  },
  "exclude": [
    "node_modules",
    "packages/components/dist",
    "packages/components/node_modules",
    "packages/components/src/**/*.test.ts",
    "packages/data/dist",
    "packages/data/node_modules",
    "packages/data/src/**/*.test.ts",
    "packages/design-tokens/dist",
    "packages/design-tokens/node_modules",
    "packages/design-tokens/src/**/*.test.ts",
    "packages/services/dist",
    "packages/services/node_modules",
    "packages/services/src/**/*.test.ts",
    "packages/types/dist",
    "packages/types/node_modules",
    "packages/types/src/**/*.test.ts",
  ],
  "include": [
    "env.d.ts",
    "vite-env.d.ts",
    "index.ts",
    "index.css",
    "packages/components/src/**/*.ts",
    "packages/data/src/**/*.ts",
    "packages/design-tokens/src/**/*.ts",
    "packages/services/src/**/*.ts",
    "packages/types/src/**/*.ts",
    "packages/.config/**/*.ts",
    "./.config/**/*.ts",
  ],
  "references": [
    {
      "path": "./packages/components/tsconfig.json",
    },
    {
      "path": "./packages/data/tsconfig.json",
    },
    {
      "path": "./packages/design-tokens/tsconfig.json",
    },
    {
      "path": "./packages/services/tsconfig.json",
    },
    {
      "path": "./packages/types/tsconfig.json",
    },
  ],
  "ts-node": {
    "compiler": "typescript",
    "logError": true,
    "pretty": true,
  },
  "typeAcquisition": {
    "enable": true,
  }
}