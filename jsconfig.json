{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "Decorators",
      "DOM",
      "DOM.Iterable",
      "ES2020",
      "ES2021",
      "ES2022",
      "ES2023",
      "ES2024",
      "ESNext",
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "checkJs": true,
    "outDir": "./website/scripts",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/dist/*": ["./dist/*"],
      "@/partials/*": ["./src/partials/*"]
    },
    "types": [
      "node",
      "eslint",
    ]
  },
  "include": [
    "src/**/*.js",
  ],
  "exclude": [
    "node_modules",
  ]
}