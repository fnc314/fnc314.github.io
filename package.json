{
  "name": "@fnc314/fnc314.github.io",
  "version": "1.0.3",
  "description": "Website for Franco N. Colaizzi - fnc314.com",
  "keywords": [
    "website",
    "homepage",
    "fnc314"
  ],
  "homepage": "https://www.fnc314.com",
  "bugs": {
    "url": "https://github.com/fnc314/fnc314.github.io/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnc314/fnc314.github.io.git"
  },
  "license": "MIT",
  "author": "Franco N. Colaizzi",
  "type": "module",
  "module": "src/index.js",
  "private": true,
  "customElements": "docs/custom-elements.json",
  "gitAbbrevHash": "",
  "gitBranch": "",
  "gitCommitHash": "",
  "gitDate": "",
  "gitVersion": "",
  "scripts": {
    "build": "bunx tsc",
    "build:watch": "bunx tsc --watch",
    "build:watch:website": "NODE_ENV=development bunx rollup -c --watch",
    "build:watch:website:prod": "NODE_ENV=production bunx rollup -c --watch",
    "checksize": "bunx rollup -c | gzip -9 | wc -c ;",
    "custom-elements-manifest": "NODE_ENV=development bunx cem analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs",
    "custom-elements-manifest:json": "bunx cem analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs --format json",
    "custom-elements-manifest:markdown": "bunx cem analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs --format markdown",
    "custom-elements-manifest:vscode": "bunx cem analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs --format vscode",
    "custom-elements-manifest:watch": "NODE_ENV=development bun run custom-elements-manifest -- --watch",
    "deploy": "rm -rfv website && bunx rollup -c",
    "deploy:test": "bunx run deploy -- --logLevel debug",
    "format": "bunx prettier \"**/*.{cjs,html,js,json,md,ts}\" --ignore-path ./.eslintignore --write",
    "lint": "bun run lint:lit-analyzer && bun run lint:eslint",
    "lint:eslint": "bunx eslint 'src/**/*.ts'",
    "lint:eslint:fix": "bunx eslint 'src/**/*.ts' --fix",
    "lint:lit-analyzer": "bunx lit-analyzer",
    "prettier": "bunx prettier .",
    "prettier:check": "bunx prettier . --check",
    "prettier:check:debug": "bunx prettier . --log-level debug --debug-check",
    "prettier:write": "bunx prettier . --write",
    "serve": "bunx wds",
    "serve:prod": "MODE=prod bun run serve -- -c web-dev-server.config.prod.mjs",
    "test": "bun run test:dev && bun run test:prod",
    "test:dev": "bunx wtr",
    "test:prod": "MODE=prod bunx wtr",
    "test:prod:watch": "MODE=prod bunx wtr --watch",
    "test:watch": "bunx wtr --watch"
  },
