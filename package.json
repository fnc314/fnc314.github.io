  "type": "module",
  "module": "src/index.ts",
  "private": true,
  "types": "./out",
  "main": "./website/index.js",
  "customElements": "docs/custom-elements-manifest/custom-elements.json",
  "web-types": "./.idea/web-types.json",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "keywords": ["website", "homepage", "fnc314"],
  "bugs": {
    "url": "https://github.com/fnc314/fnc314.github.io/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnc314/fnc314.github.io.git"
  },
  "scripts": {
    "@pwrs:cem:generate": "NODE_ENV=development pnpx @pwrs/cem generate --config .cem.yaml -v",
    "build:vite": "mise run vite:build:development",
    "build:vite:dev": "mise run vite:build:development",
    "build:vite:prod": "mise run vite:build:production",
    "cem-analyze": "NODE_ENV=development pnpm custom-elements-manifest analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs",
    "cem-analyze:watch": "NODE_ENV=development pnpm custom-elements-manifest analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs --watch",
    "dx:@pwrs:cem:generate": "pnpm run @pwrs:cem:generate",
    "dx:cem-analyze": "pnpm run cem-analyze",
    "dx:refresh": "mise run dev-ex:refresh",
    "dx:typedoc": "pnpm run typedoc:gen",
    "dx:wca": "pnpm run wca:json:file && pnpm run wca:json:files && pnpm run wca:markdown:file && pnpm run wca:markdown:files && pnpm run wca:vscode",
    "format": "pnpm prettier \"./src/**/*.{css,html,js,json,ts}\" --ignore-path ./.config/prettier/.prettierignore --write --config ./.config/prettier/prettier.config.mts",
    "lint": "pnpm run lint:lit-analyzer && pnpm run lint:eslint",
    "lint:eslint": "pnpm eslint 'src/**/*.ts' -c ./.config/eslint/eslint.config.mjs",
    "lint:eslint:fix": "pnpm eslint 'src/**/*.ts' --fix -c ./.config/eslint/eslint.config.mjs",
    "lint:lit-analyzer": "pnpm lit-analyzer",
    "prettier": "pnpm prettier . --config ./.config/prettier/prettier.config.mts --ignore-path ./.config/prettier/.prettierignore",
    "prettier:check": "pnpm prettier . --check --config ./.config/prettier/prettier.config.mts --ignore-path ./.config/prettier/.prettierignore",
    "prettier:check:debug": "pnpm prettier . --log-level debug --debug-check --config ./.config/prettier/prettier.config.mts --ignore-path ./.config/prettier/.prettierignore",
    "prettier:write": "pnpm prettier . --write --config ./.config/prettier/prettier.config.mts --ignore-path ./.config/prettier/.prettierignore",
    "serve": "pnpm wds -c ./.config/web-dev-server/web-dev-server.config.mjs",
    "serve:prod": "MODE=prod pnpm run serve -- -c ./.config/web-dev-server/web-dev-server.config.prod.mjs",
    "stylelint:config:inspector": "pnpm stylelint-config-inspector --config ./config/stylelint/stylelint.config.ts",
    "test": "pnpm run test:dev && pnpm run test:prod",
    "test:dev": "pnpm wtr",
    "test:prod": "MODE=prod pnpm wtr",
    "test:prod:watch": "MODE=prod pnpm wtr --watch",
    "test:watch": "pnpm wtr --watch",
    "typedoc:gen": "pnpm typedoc --options ./.config/typedoc/typedoc.config.mjs",
    "wca:json:file": "pnpm web-component-analyzer src/{components,partials,themes,types}/**/*.ts --outFile ./docs/wca/json/web-component-analyzer.json --format json",
    "wca:json:files": "pnpm web-component-analyzer src/{components,partials,themes,types}/**/*.ts --outDir ./docs/wca/json --format json",
    "wca:markdown:file": "pnpm web-component-analyzer src/{components,partials,themes,types}/**/*.ts --outFile ./docs/wca/markdown/README.md --format markdown",
    "wca:markdown:files": "pnpm web-component-analyzer src/{components,partials,themes,types}/**/*.ts --outDir ./docs/wca/markdown --format markdown",
    "wca:vscode": "pnpm web-component-analyzer src/{components,partials,themes,types}/**/*.ts --outDir .vscode/wca --format vscode"
  },
