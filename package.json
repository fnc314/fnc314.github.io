  "type": "module",
  "module": "src/index.js",
  "private": true,
  "types": "./website",
  "main": "./website/index.js",
  "customElements": "docs/cem/custom-elements.json",
  "gitAbbrevHash": "",
  "gitBranch": "",
  "gitCommitHash": "",
  "gitDate": "",
