{
  "name": "com.fnc314.website",
  "version": "1.0.0",
  "description": "Website for Franco N. Colaizzi - fnc314.com",
  "keywords": [
    "website",
    "homepage",
    "fnc314"
  ],
  "homepage": "https://fnc314.com",
  "bugs": {
    "url": "https://github.com/fnc314/fnc314.github.io/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnc314/fnc314.github.io.git"
  },
  "license": "MIT",
  "author": "Franco N. Colaizzi",
  "type": "module",
  "scripts": {
    "start": "web-dev-server",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:watch:website": "NODE_ENV=development rollup -c --watch",
    "build:watch:website:prod": "NODE_ENV=production rollup -c --watch",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\" --ignore-path ./.eslintignore --write",
    "docs": "npm run docs:clean && npm run build && npm run analyze && npm run docs:build && npm run docs:assets && npm run docs:gen",
    "docs:clean": "rimraf docs",
    "docs:gen": "eleventy --config=.eleventy.cjs",
    "docs:gen:watch": "eleventy --config=.eleventy.cjs --watch",
    "docs:assets": "cp node_modules/prismjs/themes/prism-okaidia.css docs/",
    "docs:serve": "wds --root-dir=docs --node-resolve --watch",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --watch",
    "pretty": "npx prettier .",
    "pretty:check": "npx prettier . --check",
    "pretty:debug": "npx prettier . --log-level debug --debug-check",
    "pretty:write": "npx prettier . --write",
    "serve": "wds",
    "serve:prod": "MODE=prod npm run serve -- -c web-dev-server.config.prod.mjs",
    "test": "npm run test:dev && npm run test:prod",
    "test:dev": "wtr",
    "test:watch": "wtr --watch",
    "test:prod": "MODE=prod wtr",
    "test:prod:watch": "MODE=prod wtr --watch",
    "test:deploy": "rm -rfv website && npx tsc && npx rollup -c --logLevel debug",
    "checksize": "rollup -c | gzip -9 | wc -c ;"
  },
  "dependencies": {
    "@lit/reactive-element": "2.1.2",
    "@material/web": "2.4.1",
    "animate-css-grid": "^1.5.1",
    "dark-mode-toggle": "^0.18.0",
    "lit": "3.3.2",
    "lit-element": "4.2.2",
    "lit-html": "3.3.2",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.40.2"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@m00nbyte/rollup-plugin-copy-multiple-assets": "^1.0.0",
    "@material/material-color-utilities": "^0.4.0",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-html": "^2.0.0",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.4.0",
    "@types/wordcloud": "^1.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/devtools": "^0.1.3",
    "@web-types/lit": "^2.0.0-3",
    "@web/dev-server": "0.4.6",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/dev-server-rollup": "^0.6.4",
    "@web/rollup-plugin-copy": "^0.5.1",
    "@web/rollup-plugin-html": "^3.1.0",
    "@web/rollup-plugin-import-meta-assets": "^2.3.3",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-json-schema-validator": "^6.2.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "lit-analyzer": "2.0.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-build-statistics": "^0.0.19",
    "rollup-plugin-clear": "^2.0.7",
    "rollup-plugin-manifest-json": "^1.7.0",
    "rollup-plugin-progress": "^1.1.2",
    "rollup-plugin-summary": "^3.0.1",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "rollup-plugin-version-injector": "^1.3.3",
    "ts-lit-plugin": "^2.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "typescript-lit-html-plugin": "^0.9.0",
    "vite": "^8.0.1"
  }
}
