    "build:vite:dev": "mise run vite:build:development",
    "build:vite:prod": "mise run vite:build:production",
    "dev": "mise run //:vite:build:development -w -d & mise run //:python:server:start dist/vite/development -p 9999",
    "lint": "pnpm run lint:lit-analyzer",
    "lint:lit-analyzer": "pnpm lit-analyzer",
    "serve": "pnpm wds -c ./.config/web-dev-server/web-dev-server.config.mjs",
    "serve:prod": "MODE=prod pnpm run serve -- -c ./.config/web-dev-server/web-dev-server.config.prod.mjs",
    "test": "pnpm run test:dev && pnpm run test:prod",
    "test:dev": "pnpm wtr --config ./.config/web-test-runner/web-test-runner.config.mjs",
    "test:prod": "MODE=prod pnpm wtr --config ./.config/web-test-runner/web-test-runner.config.mjs",
    "test:prod:watch": "MODE=prod pnpm wtr --config ./.config/web-test-runner/web-test-runner.config.mjs --watch",
    "test:watch": "pnpm wtr --config ./.config/web-test-runner/web-test-runner.config.mjs --watch"
  },
