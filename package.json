    "website",
    "homepage",
    "fnc314"
  ],
  "bugs": {
    "url": "https://github.com/fnc314/fnc314.github.io/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnc314/fnc314.github.io.git"
  },
  "scripts": {
    "@pwrs:cem:generate": "NODE_ENV=development pnpx @pwrs/cem generate --config ./.config/cem.yaml -v",
    "build": "pnpm rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript $ROLLUP_FLAGS",
    "build:dev": "NODE_ENV=development pnpm run build",
    "build:tsc": "pnpm tsc",
    "build:tsc:watch": "pnpm tsc --watch",
    "build:website": "NODE_ENV=development pnpm run build",
    "build:website:prod": "NODE_ENV=production pnpm run build",
    "build:website:watch": "NODE_ENV=development ROLLUP_FLAGS=\"--watch --logLevel debug\" pnpm run build",
    "build:website:watch:prod": "NODE_ENV=production ROLLUP_FLAGS=\"--watch --logLevel debug\" pnpm run build",
    "checksize": "pnpm run build | gzip -9 | wc -c ;",
    "cem-analyze": "NODE_ENV=development pnpm custom-elements-manifest analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs",
    "cem-analyze:watch": "NODE_ENV=development pnpm custom-elements-manifest analyze --config ./.config/custom-elements-manifest/custom-elements-manifest.config.mjs --watch",
    "deploy": "rm -rfv website && pnpm run build:website:prod",
    "deploy:test": "ROLLUP_FLAGS=\"--logLevel debug\" pnpm run deploy",
    "format": "pnpm prettier \"./src/**/*.{css,html,js,json,ts}\" --ignore-path ./.prettierignore --write",
    "lint": "pnpm run lint:lit-analyzer && pnpm run lint:eslint",
    "lint:eslint": "pnpm eslint 'src/**/*.ts'",
    "lint:eslint:fix": "pnpm eslint 'src/**/*.ts' --fix",
    "lint:lit-analyzer": "pnpm lit-analyzer",
    "prettier": "pnpm prettier .",
    "prettier:check": "pnpm prettier . --check",
    "prettier:check:debug": "pnpm prettier . --log-level debug --debug-check",
    "prettier:write": "pnpm prettier . --write",
    "serve": "pnpm wds",
    "serve:prod": "MODE=prod pnpm run serve -- -c web-dev-server.config.prod.mjs",
    "stylelint:config:inspector": "pnpm stylelint-config-inspector --config stylelint.config.ts",
    "test": "pnpm run test:dev && pnpm run test:prod",
    "test:dev": "pnpm wtr",
    "test:prod": "MODE=prod pnpm wtr",
    "test:prod:watch": "MODE=prod pnpm wtr --watch",
    "test:watch": "pnpm wtr --watch",
    "wca:json": "pnpm web-component-analyzer src/{components,partials,themes}/**/*.ts --outDir ./docs/wca/json --format json",
    "wca:markdown": "pnpm web-component-analyzer src/{components,partials,themes}/**/*.ts --outDir ./docs/wca/markdown --format markdown",
    "wca:vscode": "pnpm web-component-analyzer src/{components,partials,themes}/**/*.ts --outDir .vscode/wca --format vscode"
  },
